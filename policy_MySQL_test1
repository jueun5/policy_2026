-- table 생성 (user, policy, policy_condition)
create table users (
user_id int auto_increment primary key,  -- 사용자 id
user_name varchar(10),
age integer,  -- 나이
gender varchar(20),  -- 성별
income integer,  -- 소득
region varchar(100),  -- 지역
employment varchar(50),  -- 취업 여부
military varchar(50),  -- 군 복무 여부

created_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

-- DROP TABLE users;

create table policy (
policy_id int auto_increment primary key,  -- 정책 id
policy_name varchar(255) not null,  -- 정책 이름
description text,  -- 정책 설명
support_amount int,  -- 지원 금액
support_amount_max int,   -- 최대 지원 금액
support_type VARCHAR(50),     -- 지급 방식 (월/일시)
apply_url text,  -- 신청 링크
start_date date,  -- 시작일
end_date date,  -- 종료일
status varchar(20),  -- 상태(진헹중/종료)

created_at DATETIME DEFAULT CURRENT_TIMESTAMP
);



create table policy_condition (
condition_id int auto_increment primary key,   -- 조건 id
policy_id integer,  -- 정책 id
min_age integer,  -- 최소 나이
max_age integer,  -- 최대 나이
min_income integer,  -- 최소 소득
max_income integer,  -- 최대 소득
region varchar(100),  -- 지역
employment varchar(50),  -- 취업 조건
military varchar(50),  -- 군 복무 조건
gender varchar(20),  -- 성별 조건

foreign key (policy_id) references policy(policy_id),
created_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

