SELECT p.policy_name
FROM users u
JOIN policy_condition pc
  ON TIMESTAMPDIFF(YEAR, u.birth_date, CURDATE())
     BETWEEN pc.min_age AND pc.max_age
  AND u.income BETWEEN pc.min_income AND pc.max_income
JOIN policy p
  ON pc.policy_id = p.policy_id;

